# =====================================================
# LEXIS — Variables de entorno
#
# Copia este archivo a `.env.local` y rellena los valores.
# Las marcadas como REQUERIDA son indispensables para que arranque.
# Las OPCIONALES habilitan features específicas (audio, connectors).
# =====================================================

# -------- SUPABASE (REQUERIDA) ---------------------
# Crea un proyecto nuevo en https://supabase.com (recomendado eu-west-1).
# Settings → API te muestra estas tres values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------- EMBEDDINGS · VOYAGE (REQUERIDA) ---------------------
# Necesario para la búsqueda semántica. Plan gratuito = 200M tokens.
# Obtén la key en https://dash.voyageai.com → API keys.
VOYAGE_API_KEY=

# -------- LLM · OPENROUTER (REQUERIDA) ---------------------
# OpenRouter agrega Gemini 3 Flash (clasificación rápida) y Sonnet 4.6 (razonamiento profundo).
# Obtén la key en https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Umbral de escalación al modelo grande. 0.0 = siempre Sonnet, 1.0 = nunca.
LLM_ESCALATION_THRESHOLD=0.7

# -------- EMAIL · RESEND (REQUERIDA) ---------------------
# Magic link auth + digest periódico. Obtén la key en https://resend.com/api-keys.
# Si tu dominio aún no está verificado, RESEND_FROM puede ser onboarding@resend.dev (solo en sandbox).
RESEND_API_KEY=
RESEND_FROM="Lexis <noreply@tu-dominio.com>"
RESEND_DIGEST_FROM="Lexis Digest <digest@tu-dominio.com>"

# -------- APP (REQUERIDA) ---------------------
# Base URL pública. En dev: http://localhost:3000. En producción: tu dominio Cloudflare Pages.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------- CRON (REQUERIDA en producción) ---------------------
# Secret aleatorio que protege /api/cron/*. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# En Cloudflare Pages: añadir como variable + Cron Trigger horario llamando POST /api/cron/connectors,
# /api/cron/digest y /api/cron/refresh-summaries con header Authorization: Bearer $CRON_SECRET.
CRON_SECRET=

# -------- AUDIO (OPCIONAL — habilita captura por voz) ---------------------
# Provider: "openai" o "groq". Groq es más barato y rápido pero solo transcribe (no TTS).
# Si quieres TTS para el entrevistador, usa openai.
AUDIO_PROVIDER=openai

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
TTS_VOICE=nova
TTS_MODEL=tts-1

# Groq (alternativa rápida y barata para Whisper): https://console.groq.com/keys
GROQ_API_KEY=

# -------- GOOGLE OAUTH (OPCIONAL — habilita Gmail, Drive y Calendar connectors) -----------
# Pre-requisitos en Google Cloud Console (https://console.cloud.google.com):
#   1. Crear proyecto.
#   2. APIs & Services → Library → habilitar:
#        - Gmail API
#        - Google Drive API
#        - Google Calendar API     ← AÑADIDO en Sprint 14
#        - Google People API (para userinfo)
#   3. OAuth consent screen → External → añadir scopes:
#        - openid, email
#        - https://www.googleapis.com/auth/gmail.readonly
#        - https://www.googleapis.com/auth/drive.readonly
#        - https://www.googleapis.com/auth/calendar        ← AÑADIDO Sprint 14 (full, no readonly)
#      Si está en modo "Testing", añadirte como test user.
#   4. Credentials → Create Credentials → OAuth client ID → Web application:
#        - Authorized redirect URIs:
#            http://localhost:3000/api/oauth/google/callback
#            ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback (en producción)
#   5. Anotar Client ID y Client secret.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Secret aleatorio para firmar el state CSRF del OAuth. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=

# -------- WEB PUSH (VAPID) — Sprint 16 -----------------------------------------------------
# Permite a Lexis enviar push notifications a la PWA instalada.
# Genera las claves UNA vez con:
#   npx web-push generate-vapid-keys
#
# Pega aquí las dos claves devueltas. La pública también se expone al cliente
# a través de /api/push/subscribe (GET), no la metas en NEXT_PUBLIC_ — el server
# la devuelve solo a usuarios autenticados.
#
# VAPID_SUBJECT debe ser un mailto: o una https:// URL. Algunos proveedores
# (FCM) son estrictos con esto; usa un email real al que monitoreen.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@email.com
